<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
	<DataCollectionRunSettings>
		<DataCollectors>
			<DataCollector friendlyName="XPlat code coverage">
				<Configuration>
					<Format>cobertura</Format>
					<ExcludeByAttribute>
						Obsolete,
						ExcludeFromCodeCoverage,
						GeneratedCodeAttribute,
						TestSDKAutoGeneratedCode
					</ExcludeByAttribute>
					<IncludeTestAssembly>false</IncludeTestAssembly>
					<SkipAutoProps>true</SkipAutoProps>
					<ExcludeAssembliesWithoutSources>
						MissingAll,
						MissingAny,
						None
					</ExcludeAssembliesWithoutSources>
					<Exclude>
						*[EdiFabric.Templates]*,
						*[Rethink.Services.Domain]*,
						*[Rethink.Services.Common]*,
						*[BillingService.XUnit.Tests]*,
						*[BillingService.XUnit.Integration.Tests]*,
						*[BillingService.XUnit.Tests.Common]*,
					</Exclude>
					<Include>
						*[BillingService.Web.*]*
					</Include>
					<ExcludeByFile>
						**/BillingService.Web/Program.cs,
						**/BillingService.Web/Startup.cs,
					</ExcludeByFile>
				</Configuration>
			</DataCollector>
		</DataCollectors>
	</DataCollectionRunSettings>
</RunSettings>
