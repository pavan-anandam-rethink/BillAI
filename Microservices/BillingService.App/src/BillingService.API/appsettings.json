{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Server=sql;Database=BillingDb;User Id=billing;Password=ChangeMe!;TrustServerCertificate=True;",
    "BillingOutbox": "Server=sql;Database=BillingDb;User Id=billing;Password=ChangeMe!;TrustServerCertificate=True;",
    "Redis": "redis:6379",
    "ServiceBus": ""
  },
  "BillingModernization": {
    "UseLegacyProxyFallback": true,
    "ClaimHeadersMigrationMode": "Off",
    "UseCqrsDashboard": false,
    "ClaimHeaderTtlSeconds": 30,
    "DashboardSummaryTtlSeconds": 120,
    "ExposeModernizationStatusEndpoint": false
  },
  "LegacyBilling": {
    "BaseUrl": "http://billingservice-web",
    "TimeoutSeconds": 30
  },
  "Telemetry": {
    "ServiceName": "billingservice-app",
    "OtlpEndpoint": "http://otel-collector:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "legacy-fallback": {
        "ClusterId": "legacy-billing",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "legacy-billing": {
        "Destinations": {
          "d1": {
            "Address": "http://billingservice-web/"
          }
        }
      }
    }
  }
}

