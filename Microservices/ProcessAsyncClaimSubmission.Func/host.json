{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true
      }
    },
    "logLevel": {
      "default": "Information",
      "Host": "Information",
      "Function": "Information",
      "Worker": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "extensions": {
    "serviceBus": {
      "messageHandlerOptions": {
        "maxConcurrentCalls": 30,
        "autoCompleteMessages": false,
        "maxAutoRenewDuration": "00:10:00"
      },
      "prefetchCount": 100
    }
  }
}