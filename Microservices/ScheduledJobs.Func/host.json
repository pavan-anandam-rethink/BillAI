{
  "version": "2.0",
  "functionTimeout": "00:15:00",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Function": "Information",
      "Host.Results": "Information",
      "Host.Aggregator": "Information"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveMetricsFilters": true
    }
  },
  "extensions": {
    "timers": {
      "scheduleMonitor": {
        "useMonitor": true
      }
    }
  }
}
