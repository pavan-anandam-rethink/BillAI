{
  "Logging": {
    "AppInsightsLogger": {
      "IsEnabled": true,
      "LogLevel": {
        "Default": "Information",
        "Microsoft": "Error",
        "System": "Warning",
        "Rethink": "Information"
      }
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "Dev--Billing--ApplicationInsights--InstrumentationKey",
    "APPLICATIONINSIGHTS_CONNECTION_STRING": "Dev--Billing--ApplicationInsights--Connection--String"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": {
      "DataSource": "rta-bh-dev-internal-sql.database.windows.net",
      "InitialCatalog": "rta-billing-dev-sql-db1",
      "IntegratedSecurity": false,
      "MultiSubnetFailover": true,
      "UserId": "Dev--Billing--ConnectionStrings--Database--UserId",
      "Password": "Dev--Billing--ConnectionStrings--Database--Password",
      "Encrypt": true,
      "TrustServerCertificate": false,
      "ConnectionTimeout": 16000
    },
    "ReportingDB": {
      "DataSource": "rta-bh-dev-internal-sql.database.windows.net",
      "InitialCatalog": "rta-billing-dev-sql-db1",
      "IntegratedSecurity": false,
      "MultiSubnetFailover": true,
      "UserId": "Dev--Billing--ConnectionStrings--ReportingDB--UserId",
      "Password": "Dev--Billing--ConnectionStrings--ReportingDB--Password",
      "Encrypt": true,
      "TrustServerCertificate": false,
      "ConnectionTimeout": 16000
    },
    "ServiceBus": {
      "ConnectionString": "Dev--Billing--ConnectionStrings--ServiceBus--ConnectionString"
    },
    "BlobStorage": {
      "ConnectionString": "Dev--Billing--ConnectionStrings--BlobStorage--ConnectionString"
    },
    "RedisCache": {
      "ConnectionString": "Dev--Billing--ConnectionStrings--RedisCache--ConnectionString"
    }
